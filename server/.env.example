PORT=5000
MONGO_URI=<your-mongodb-connection-string>
DB_NAME=ai-website-builder
JWT_SECRET=<your-strong-jwt-secret>
IN_PROD=true
OPENAI_API_KEY=<your-openrouter-api-key>
OPENAI_MODEL=deepseek/deepseek-chat
DEPLOYMENT_URL=https://your-frontend-domain/sites
# Optional: comma-separated extra allowed browser origins (Vercel previews, staging).
# CORS_ORIGINS=https://your-app-git-main-xxx.vercel.app,https://staging.example.com

# Stripe (required for server boot if payments.controller loads Stripe at startup)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Must match your Next app routes (protected) after checkout:
STRIPE_SUCCESS_URL=https://app.yourdomain.com/payment/success
STRIPE_CANCEL_URL=https://app.yourdomain.com/payment/cancel